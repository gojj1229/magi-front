{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · institutional persona — DTCG tokens. Mirror of design-md/institutional.md frontmatter.",
  "color": {
    "primary": { "$value": "#1E3A5F", "$type": "color" },
    "accent": { "$value": "#2C5282", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FFFFFF", "$type": "color" },
      "secondary": { "$value": "#F8F9FA", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#1A1F2E", "$type": "color" },
      "secondary": { "$value": "#4A5568", "$type": "color" }
    },
    "border": { "$value": "#CBD5E0", "$type": "color" },
    "dark": {
      "bg": {
        "primary": { "$value": "#1A1F2E", "$type": "color" },
        "secondary": { "$value": "#252B3D", "$type": "color" }
      },
      "text": {
        "primary": { "$value": "#E2E8F0", "$type": "color" },
        "secondary": { "$value": "#A0AEC0", "$type": "color" }
      },
      "border": { "$value": "#2D3748", "$type": "color" },
      "primary": { "$value": "#5285B8", "$type": "color" },
      "accent": { "$value": "#6499D8", "$type": "color" }
    },
    "status": {
      "success": { "$value": "#2D7A4E", "$type": "color" },
      "warning": { "$value": "#B47914", "$type": "color" },
      "error": { "$value": "#9B1C1C", "$type": "color" },
