{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · community persona — DTCG tokens. Mirror of design-md/community.md frontmatter.",
  "color": {
    "primary": { "$value": "#E89B7A", "$type": "color" },
    "accent": { "$value": "#8FAB94", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FBF6F1", "$type": "color" },
      "secondary": { "$value": "#F4ECE2", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#3A2E25", "$type": "color" },
      "secondary": { "$value": "#7A6856", "$type": "color" }
    },
    "border": { "$value": "#EADFD0", "$type": "color" },
    "status": {
      "success": { "$value": "#7A9B5E", "$type": "color" },
      "warning": { "$value": "#D4944A", "$type": "color" },
      "error": { "$value": "#C76A6A", "$type": "color" },
      "info": { "$value": "#6E8FA6", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "Pretendard, 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif", "$type": "fontFamily" },
      "body": { "$value": "Pretendard, 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "20px", "$type": "dimension" },
      "xl": { "$value": "26px", "$type": "dimension" },
      "2xl": { "$value": "36px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "16px", "$type": "dimension" },
    "4": { "$value": "24px", "$type": "dimension" },
    "5": { "$value": "40px", "$type": "dimension" },
    "6": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  }
}
