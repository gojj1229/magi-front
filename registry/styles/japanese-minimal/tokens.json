{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · japanese-minimal persona — DTCG tokens. Mirror of design-md/japanese-minimal.md frontmatter.",
  "color": {
    "primary": { "$value": "#0A0A0A", "$type": "color" },
    "accent": { "$value": "#1F8A4F", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FFFFFF", "$type": "color" },
      "secondary": { "$value": "#F5F5F5", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#0A0A0A", "$type": "color" },
      "secondary": { "$value": "#5C5C5C", "$type": "color" }
    },
    "border": { "$value": "#E0E0E0", "$type": "color" },
    "status": {
      "success": { "$value": "#1F8A4F", "$type": "color" },
      "warning": { "$value": "#C97A1F", "$type": "color" },
      "error": { "$value": "#B82828", "$type": "color" },
      "info": { "$value": "#2B5F8E", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif", "$type": "fontFamily" },
      "body": { "$value": "'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "11px", "$type": "dimension" },
      "sm": { "$value": "12px", "$type": "dimension" },
      "base": { "$value": "13px", "$type": "dimension" },
      "lg": { "$value": "14px", "$type": "dimension" },
      "xl": { "$value": "18px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "40px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" }
  }
}
