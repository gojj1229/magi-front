{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · editorial persona — DTCG tokens. Mirror of design-md/editorial.md frontmatter.",
  "color": {
    "primary": { "$value": "#2A2520", "$type": "color" },
    "accent": { "$value": "#C8923A", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FBF9F5", "$type": "color" },
      "secondary": { "$value": "#F1ECE3", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#1F1B16", "$type": "color" },
      "secondary": { "$value": "#6B5F50", "$type": "color" }
    },
    "border": { "$value": "#E5DDCE", "$type": "color" },
    "status": {
      "success": { "$value": "#6B7B3E", "$type": "color" },
      "warning": { "$value": "#B8702E", "$type": "color" },
      "error": { "$value": "#A83838", "$type": "color" },
      "info": { "$value": "#5A6F8E", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "'Noto Serif JP', 'Noto Serif KR', 'Source Serif Pro', serif", "$type": "fontFamily" },
      "body": { "$value": "'Noto Serif JP', 'Noto Serif KR', 'Source Serif Pro', serif", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "13px", "$type": "dimension" },
      "sm": { "$value": "15px", "$type": "dimension" },
      "base": { "$value": "17px", "$type": "dimension" },
      "lg": { "$value": "22px", "$type": "dimension" },
      "xl": { "$value": "30px", "$type": "dimension" },
      "2xl": { "$value": "44px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "16px", "$type": "dimension" },
    "4": { "$value": "24px", "$type": "dimension" },
    "5": { "$value": "40px", "$type": "dimension" },
    "6": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" }
  }
}
