{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · dev-technical persona — DTCG tokens. Mirror of design-md/dev-technical.md frontmatter.",
  "color": {
    "primary": { "$value": "#0F0F12", "$type": "color" },
    "accent": { "$value": "#0EA5E9", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FAFAFA", "$type": "color" },
      "secondary": { "$value": "#F4F4F5", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#0F0F12", "$type": "color" },
      "secondary": { "$value": "#71717A", "$type": "color" }
    },
    "border": { "$value": "#E4E4E7", "$type": "color" },
    "dark": {
      "bg": {
        "primary": { "$value": "#0A0A0F", "$type": "color" },
        "secondary": { "$value": "#18181B", "$type": "color" }
      },
      "text": {
        "primary": { "$value": "#FAFAFA", "$type": "color" },
        "secondary": { "$value": "#A1A1AA", "$type": "color" }
      },
      "border": { "$value": "#27272A", "$type": "color" },
      "accent": { "$value": "#38BDF8", "$type": "color" }
    },
    "status": {
      "success": { "$value": "#22C55E", "$type": "color" },
      "warning": { "$value": "#F59E0B", "$type": "color" },
      "error": { "$value": "#EF4444", "$type": "color" },
      "info": { "$value": "#0EA5E9", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "'Geist', 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "body": { "$value": "'Geist', 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'Geist Mono', 'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "13px", "$type": "dimension" },
      "base": { "$value": "14px", "$type": "dimension" },
      "lg": { "$value": "16px", "$type": "dimension" },
      "xl": { "$value": "22px", "$type": "dimension" },
      "2xl": { "$value": "32px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "24px", "$type": "dimension" },
    "6": { "$value": "40px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" }
  }
}
