{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · playful-friendly persona — DTCG tokens. Mirror of design-md/playful-friendly.md frontmatter.",
  "color": {
    "primary": { "$value": "#8B5CF6", "$type": "color" },
    "accent": { "$value": "#FBBF24", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FFFFFF", "$type": "color" },
      "secondary": { "$value": "#FAF7FF", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#1C1917", "$type": "color" },
      "secondary": { "$value": "#57534E", "$type": "color" }
    },
    "border": { "$value": "#E7E5E4", "$type": "color" },
    "dark": {
      "bg": {
        "primary": { "$value": "#1A1626", "$type": "color" },
        "secondary": { "$value": "#251F33", "$type": "color" }
      },
      "text": {
        "primary": { "$value": "#FAF7FF", "$type": "color" },
        "secondary": { "$value": "#B5B0BF", "$type": "color" }
      },
      "border": { "$value": "#3D3447", "$type": "color" },
      "primary": { "$value": "#A78BFA", "$type": "color" },
      "accent": { "$value": "#FCD34D", "$type": "color" }
    },
    "status": {
      "success": { "$value": "#84CC16", "$type": "color" },
      "warning": { "$value": "#FBBF24", "$type": "color" },
      "error": { "$value": "#F43F5E", "$type": "color" },
      "info": { "$value": "#8B5CF6", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "'Plus Jakarta Sans', 'Quicksand', 'Pretendard', sans-serif", "$type": "fontFamily" },
      "body": { "$value": "'Plus Jakarta Sans', 'Inter', 'Pretendard', sans-serif", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "14px", "$type": "dimension" },
      "sm": { "$value": "16px", "$type": "dimension" },
      "base": { "$value": "18px", "$type": "dimension" },
      "lg": { "$value": "22px", "$type": "dimension" },
      "xl": { "$value": "30px", "$type": "dimension" },
      "2xl": { "$value": "48px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "16px", "$type": "dimension" },
    "4": { "$value": "24px", "$type": "dimension" },
    "5": { "$value": "40px", "$type": "dimension" },
    "6": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  }
}
