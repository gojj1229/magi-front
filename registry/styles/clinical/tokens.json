{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "magi-front · clinical persona — DTCG tokens. Mirror of design-md/clinical.md frontmatter.",
  "color": {
    "primary": { "$value": "#0F6E7C", "$type": "color" },
    "accent": { "$value": "#4A8C7A", "$type": "color" },
    "bg": {
      "primary": { "$value": "#FAFBFC", "$type": "color" },
      "secondary": { "$value": "#F2F5F7", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#0F1419", "$type": "color" },
      "secondary": { "$value": "#5A6772", "$type": "color" }
    },
    "border": { "$value": "#DCE3E8", "$type": "color" },
    "status": {
      "success": { "$value": "#2D7A4E", "$type": "color" },
      "warning": { "$value": "#B8702E", "$type": "color" },
      "error": { "$value": "#B83A3A", "$type": "color" },
      "info": { "$value": "#2B6CB0", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "heading": { "$value": "Pretendard, 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif", "$type": "fontFamily" },
      "body": { "$value": "Pretendard, 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "20px", "$type": "dimension" },
      "xl": { "$value": "28px", "$type": "dimension" },
      "2xl": { "$value": "40px", "$type": "dimension" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "16px", "$type": "dimension" },
    "4": { "$value": "24px", "$type": "dimension" },
    "5": { "$value": "40px", "$type": "dimension" },
    "6": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" }
  }
}
